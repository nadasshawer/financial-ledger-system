<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nada C++ Example</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css"
    />
    <style>
      main {
        max-width: 760px;
        margin: 2rem auto;
      }
      #result {
        margin-top: 1rem;
        font-size: 1.1rem;
      }
    </style>
  </head>
  <body>
    <main class="container">
      <h1>Nada C++ Example</h1>
      <p>Enter two integers and click <strong>Add</strong>.</p>

      <form method="post" action="/">
        <label for="a">First Number</label>
        <input id="a" name="a" type="number" required />

        <label for="b">Second Number</label>
        <input id="b" name="b" type="number" required />

        <button type="submit">Add</button>
      </form>
      <p id="result" aria-live="polite">
        Result: <strong><%= calculation.result %></strong>
      </p>
    </main>
  </body>
</html>
